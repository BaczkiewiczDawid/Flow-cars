# --- Baza danych (Drizzle + libSQL/SQLite) ---
# Lokalnie wystarczy plik SQLite, nie trzeba stawiać żadnego serwera bazy danych.
DATABASE_URL="file:./local.db"
# Potrzebne tylko jeśli DATABASE_URL wskazuje na zdalną bazę Turso (libsql://...)
DATABASE_AUTH_TOKEN=""

# --- Scraper ---
# "live"  -> (DOMYŚLNY) scraper pobiera i parsuje prawdziwe strony olx.pl i otomoto.pl.
#            Adresy URL i pola są oparte na realnej strukturze stron zweryfikowanej
#            ręcznie - zobacz komentarze w lib/scrapers/olx.ts i otomoto.ts oraz
#            README ("Co działa, a co może wymagać poprawki").
# "mock"  -> scraper korzysta z danych przykładowych (przydatne do podglądu UI
#            bez wysyłania żadnych requestów, albo jeśli live jest zablokowane).
SCRAPER_MODE="live"

# Ile ogłoszeń maksymalnie pobieramy ze szczegółami dla jednego modelu z listy
# obserwowanych (WATCHLIST w lib/scrapers/catalog.ts) w jednym skanie.
# Pełny skan = 7 modeli x 2 serwisy x (1 strona wyników + tyle szczegółów),
# z odstępem SCRAPER_DELAY_MS między KAŻDYM requestem - przy domyślnych
# wartościach to ok. 2-3 minuty. Przycisk na dashboardzie ma sens dla
# szybkich doraźnych skanów; do dużych/regularnych skanów lepiej użyć
# `npm run scrape` w terminalu (nie ogranicza go timeout requestu HTTP).
SCRAPER_MAX_LISTINGS="8"

# Jak długo (ms) scraper czeka między kolejnymi requestami w trybie "live",
# żeby nie zarzucac serwisow zapytaniami.
SCRAPER_DELAY_MS="1500"

# --- Reguła "okazji" ---
# O ile procent cena ogłoszenia musi być niższa od wyliczonej ceny rynkowej,
# żeby auto zostało oznaczone jako okazja (poniżej rynku).
UNDERPRICED_THRESHOLD_PERCENT="15"

# Minimalna liczba porównywalnych ogłoszeń w bazie, żeby uznać wycenę rynkową za wiarygodną.
MIN_COMPARABLE_SAMPLE="3"
